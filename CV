  // Grid Data (16 columns × 20 rows)
  var g = [
    // row 0 — top hair
    [T,  T,  T,  GH, GH, GH, GH, GH, GH, GH, GH, GH, T,  T,  T,  T ],
    // row 1 — hair
    [T,  T,  GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, T,  T,  T ],
    // row 2 — hair
    [T,  GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, T,  T ],
    // row 3 — full hair width
    [GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, GH, T ],
    // row 4 — hairline / forehead
    [GH, GH, GH, SK, SK, SK, SK, SK, SK, SK, SK, SK, GH, GH, GH, T ],
    // row 5 — forehead
    [T,  GH, SK, SK, SK, SK, SK, SK, SK, SK, SK, SK, SK, GH, T,  T ],
    // row 6 — eyebrows
    [T,  GH, SK, GL, GL, SK, SK, SK, SK, SK, GL, GL, SK, GH, T,  T ],
    // row 7 — glasses top frame
    [T,  SK, GR, GR, GR, GR, SK, SK, SK, GR, GR, GR, GR, SK, T,  T ],
    // row 8 — eyes / lenses
    [T,  SK, GR, EY, PU, GR, SK, SK, SK, GR, EY, PU, GR, SK, T,  T ],
    // row 9 — glasses bottom frame
    [T,  SK, GR, GR, GR, GR, SK, SK, SK, GR, GR, GR, GR, SK, T,  T ],
    // row 10 — cheeks / nose
    [T,  S2, SK, SK, SK, SK, SK, SK, SK, SK, SK, SK, SK, S2, T,  T ],
    // row 11 — cheeks beard start
    [T,  BD, SK, SK, SK, SK, SK, SK, SK, SK, SK, SK, SK, BD, T,  T ],
    // row 12 — mustache
    [T,  BD, BD, BD, SK, BD, BD, BD, BD, BD, SK, BD, BD, BD, T,  T ],
    // row 13 — full beard
    [T,  BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, T,  T ],
    // row 14 — beard full depth
    [T,  T,  BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, T,  T,  T ],
    // row 15 — beard narrow
    [T,  T,  BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, BD, T,  T,  T ],
    // row 16 — beard tip
    [T,  T,  T,  BD, BD, BD, BD, BD, BD, BD, BD, T,  T,  T,  T,  T ],
    // row 17 — neck / shirt start
    [T,  T,  T,  WT, WT, WS, WS, WS, WS, WS, WT, WT, T,  T,  T,  T ],
    // row 18 — shirt shoulders / logo
    [T,  WT, WT, WT, WT, WT, WT, WT, WT, LG, LG, WT, WT, WT, T,  T ],
    // row 19 — full shirt body
    [WT, WT, WT, WT, WT, WT, WT, WT, WT, WT, WT, WT, WT, WT, WT, WT]
  ];

  var cv = document.getElementById("av");
  cv.width  = W * S;
  cv.height = H * S;
  var ctx = cv.getContext("2d");
  ctx.imageSmoothingEnabled = false;

  for (var r = 0; r < H; r++) {
    for (var c = 0; c < W; c++) {
      if (g[r][c] === "T") continue;
      ctx.fillStyle = g[r][c];
      ctx.fillRect(c * S, r * S, S, S);
    }
  }
}());

