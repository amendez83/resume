<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>amendez.me — bash — 80×24</title>
<link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg:      #0d1117; /* GitHub Dark */
    --surface: #161b22;
    --border:  #30363d;
    --prompt:  #f78166;
    --cmd:     #e6edf3;
    --output:  #8b949e;
    --green:   #3fb950;
    --blue:    #58a6ff;
    --yellow:  #d29922;
    --orange:  #f0883e;
    --dim:     #484f58;
  }

  body {
    background: var(--bg);
    color: var(--cmd);
    font-family: 'VT323', monospace;
    font-size: 18px;
    line-height: 1.5;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 30px 15px;
    position: relative;
  }

  /* CRT scanlines effect */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 2px,
      rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 3px
    );
    pointer-events: none;
    z-index: 9999;
  }

  .window {
    width: 100%;
    max-width: 820px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 70px rgba(0,0,0,0.7);
  }

  .titlebar {
    background: #161b22;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 12px 16px;
    gap: 9px;
    user-select: none;
  }
  .dot { width: 13px; height: 13px; border-radius: 50%; flex-shrink: 0; }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }
  .tlabel {
    flex: 1; text-align: center;
    color: var(--output); font-size: 16px; letter-spacing: 0.5px;
    padding-right: 25px; /* balance dots */
  }

  .term { padding: 25px 30px 35px; }

  /* New Header Layout */
  .header-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    margin-bottom: 30px;
    padding-bottom: 25px;
    border-bottom: 1px solid var(--border);
  }

  canvas#av {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    flex-shrink: 0;
    /* Clean look: no border, just the art on background */
    display: block;
  }

  .htext { display: flex; flex-direction: column; justify-content: center; }
  .hname  { font-size: 42px; color: var(--cmd); letter-spacing: 1px; line-height: 1; min-height: 45px; }
  .htitle { font-size: 22px; color: var(--green); margin-top: 2px; min-height: 24px; }
  .hloc   { font-size: 18px; color: var(--output); margin-top: 4px; min-height: 20px; }

  /* Responsive Header */
  @media (max-width: 600px) {
    .header-row { flex-direction: column; gap: 15px; text-align: center; }
    .htext { align-items: center; }
  }

  /* Terminal content styles */
  .pline {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 6px; opacity: 0; transition: opacity 0.1s;
  }
  .pline.show { opacity: 1; }
  .ps1  { color: var(--prompt); font-size: 20px; font-weight: bold; }
  .pcmd { color: var(--cmd);    font-size: 20px; }

  .cur {
    display: inline-block; width: 10px; height: 20px;
    background: var(--cmd); vertical-align: middle;
    animation: blink 1s step-start infinite;
    margin-left: 2px;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  .oblock {
    padding-left: 0; margin-bottom: 22px;
    opacity: 0; transform: translateY(5px);
    transition: opacity 0.25s, transform 0.25s;
  }
  .oblock.show { opacity: 1; transform: none; }

  .oline   { color: var(--output); font-size: 18px; line-height: 1.6; }
  .oline.w { color: var(--cmd); font-weight: bold; }
  .oline.g { color: var(--green); }
  .oline.b { color: var(--blue); }
  .oline.o { color: var(--orange); }
  .oline.y { color: var(--yellow); }

  .dirlist { display: flex; flex-wrap: wrap; gap: 8px 30px; margin-top: 4px; }
  .ditem { color: var(--blue); font-size: 18px; }
  .ditem::before { content: "d "; color: var(--dim); }

  .pbox {
    border: 1px solid var(--border);
    border-left: 4px solid var(--orange);
    background: var(--surface);
    padding: 15px 20px; margin: 5px 0 18px;
    border-radius: 4px;
    opacity: 0; transform: translateY(5px);
    transition: opacity 0.3s, transform 0.3s;
  }
  .pbox.show { opacity: 1; transform: none; }
  .ptitle { color: var(--orange); font-size: 22px; margin-bottom: 4px; font-weight: bold; }
  .prole  { color: var(--yellow); font-size: 17px; margin-bottom: 8px; }
  .pdesc  { color: var(--output); font-size: 17px; line-height: 1.6; margin-bottom: 10px; }
  .ptags  { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    background: rgba(88,166,255,0.1);
    border: 1px solid rgba(88,166,255,0.2);
    color: var(--blue); font-size: 15px;
    padding: 2px 10px; border-radius: 4px;
  }

  .clinks { display: flex; flex-wrap: wrap; gap: 8px 30px; margin-top: 5px; }
  .clinks a { color: var(--blue); text-decoration: none; font-size: 18px; transition: color 0.15s; }
  .clinks a:hover { color: var(--cmd); text-decoration: underline; }
  .clinks a::before { content: "-> "; color: var(--dim); }

  .fprompt { display: flex; align-items: center; gap: 10px; margin-top: 15px; opacity: 0; transition: opacity 0.3s; }
  .fprompt.show { opacity: 1; }

</style>
</head>
<body>

