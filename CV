<script>
"use strict";

// ── PIXEL ART AVATAR (Updated to match image_15.png) ─────────────────────
(function() {
  // Scaling and grid setup (16x20 base grid)
  var S = 7, W = 16, H = 20;

  // Color Palette from new profile picture
  var T  = "T";       // transparent
  var GH = "#3c584c"; // Green-grey hair
  var SK = "#eead88"; // Peach skin
  var S2 = "#cd8b66"; // Skin shadow
  var GR = "#a0ffe0"; // Lighter Green glasses frame
