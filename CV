// ── HELPERS ───────────────────────────────────────────────────────────────
var term = document.getElementById("term");

function wait(ms) {
  return new Promise(function(res){ setTimeout(res, ms); });
}

function typeInto(el, text, base, variance) {
  return new Promise(function(res) {
    var i = 0;
    function tick() {
      if (i < text.length) {
        el.textContent += text.charAt(i++);
        setTimeout(tick, base + Math.random() * variance);
      } else { res(); }
    }
    tick();
  });
}

function makePromptLine() {
  var line = document.createElement("div");
  line.className = "pline";
  var s = document.createElement("span"); s.className = "ps1"; s.textContent = "\u276f";
  var c = document.createElement("span"); c.className = "pcmd";
  var k = document.createElement("span"); k.className = "cur";
  line.appendChild(s); line.appendChild(c); line.appendChild(k);
  term.appendChild(line);
  return { line: line, cmd: c, cur: k };
}

function makeOblock() {
  var d = document.createElement("div");
  d.className = "oblock";
  term.appendChild(d);
  return d;
}

function addLine(container, text, cls) {
  var div = document.createElement("div");
  div.className = cls ? ("oline " + cls) : "oline";
  div.textContent = text;
  container.appendChild(div);
}

function show(el) {
  requestAnimationFrame(function(){ el.classList.add("show"); });
}

async function typeCmd(text) {
  var p = makePromptLine();
  await wait(180);
  p.line.classList.add("show");
  await typeInto(p.cmd, text, 38, 22);
  p.cur.remove();
  await wait(160);
}

// ── SEQUENCE ─────────────────────────────────────────────────────────────
async function runSequence() {
  await wait(500);

  // whoami
  await typeCmd("whoami");
  var w = makeOblock();
  addLine(w, "\xc1LEX M\xc9NDEZ", "w");
  addLine(w, "Product Designer  \xb7  Design Engineer", "g");
  addLine(w, "Madrid, España \u2014 amendez.me");
  show(w);
  await wait(850);

  // cat about.txt
  await typeCmd("cat about.txt");
  var ab = makeOblock();
  PROFILE.forEach(function(l){ addLine(ab, l); });
  show(ab);
  await wait(850);

  // ls work/
  await typeCmd("ls work/");
  var ls = makeOblock();
  var dl = document.createElement("div"); dl.className = "dirlist";
  PROJECTS.forEach(function(p){
    var d = document.createElement("div"); d.className = "ditem";
    d.textContent = p.file.split("/")[1];
    dl.appendChild(d);
  });
  ls.appendChild(dl);
  show(ls);
  await wait(750);

  // projects
  for (var i = 0; i < PROJECTS.length; i++) {
    var proj = PROJECTS[i];
    await typeCmd("cat " + proj.file);

    var box = document.createElement("div"); box.className = "pbox";
    var pt = document.createElement("div"); pt.className = "ptitle"; pt.textContent = proj.title;
    var pr = document.createElement("div"); pr.className = "prole";  pr.textContent = proj.role;
    var pd = document.createElement("div"); pd.className = "pdesc";  pd.textContent = proj.desc;
    var pg = document.createElement("div"); pg.className = "ptags";
    proj.tags.forEach(function(t){
      var tg = document.createElement("span"); tg.className = "tag"; tg.textContent = t;
      pg.appendChild(tg);
    });
    box.appendChild(pt); box.appendChild(pr); box.appendChild(pd); box.appendChild(pg);
    term.appendChild(box);
    show(box);
    await wait(750);
  }

  // cat contact.txt
  await typeCmd("cat contact.txt");
  var co = makeOblock();
  var cl = document.createElement("div"); cl.className = "clinks";
  CONTACTS.forEach(function(c){
    var a = document.createElement("a");
    a.href = c.href; a.textContent = c.label;
    a.target = "_blank"; a.rel = "noopener noreferrer";
    cl.appendChild(a);
  });
  co.appendChild(cl);
  show(co);
  await wait(600);

  // final cursor
  var fp = document.createElement("div"); fp.className = "fprompt";
  var fs = document.createElement("span"); fs.className = "ps1"; fs.textContent = "\u276f";
  var fc = document.createElement("span"); fc.className = "cur";
  fp.appendChild(fs); fp.appendChild(fc);
  term.appendChild(fp);
  await wait(80);
  fp.classList.add("show");
}

// ── HEADER TYPEWRITER ─────────────────────────────────────────────────────
window.addEventListener("DOMContentLoaded", async function() {
